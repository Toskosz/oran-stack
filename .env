# ============================================================================
# Open5GS 5G Core Network - Docker Compose Configuration
# ============================================================================
# This file contains all configurable parameters for the 5G core network.
# IMPORTANT: These variables are injected into NF configuration YAML files at
# container startup via envsubst. Changing values here requires recreating or
# restarting the affected containers so entrypoints rerun envsubst; rebuilding
# Docker images is only needed when the config templates themselves change.
# NOTE: Docker Compose only passes these variables into containers when they
# are referenced in docker-compose.yml via ${VAR} or listed under env_file.

# ============================================================================
# PLMN Configuration (CRITICAL - Customizable)
# ============================================================================
# MCC: Mobile Country Code (typically 3 digits, 001 = test network)
# MNC: Mobile Network Code (typically 2-3 digits, 01 = test network)
# TAC: Tracking Area Code (used for location management)
MCC=001
MNC=01
TAC=1

# ============================================================================
# AMF Configuration
# ============================================================================
# AMF_REGION: Regional identification for the AMF
# AMF_SET: Set identification for the AMF
# Note: Region + Set make up the AMF ID in GUAMI (GUMMEI equivalent)
AMF_REGION=2
AMF_SET=1

# ============================================================================
# MME Configuration (4G)
# ============================================================================
# MME_GID: MME Group ID (part of GUMMEI)
# MME_CODE: MME Code (part of GUMMEI)
MME_GID=2
MME_CODE=1

# ============================================================================
# Network Slice Configuration
# ============================================================================
# Two slices are deployed for the anomaly detection system:
#   Slice 1 (SST=1, SD=1): baseline eMBB slice   → SMF/UPF at 172.20.0.4/7
#   Slice 2 (SST=1, SD=5): anomaly-watched slice  → SMF2/UPF2 at 172.20.0.22/23
# The RC xApp enforces per-slice PRB quotas via E2SM-RC based on anomaly ratios
# reported by the ADS sidecars, which sniff UPF traffic and classify flows using
# the FHE-encrypted RandomForest model.
NSSAI_SST=1
NSSAI_SD_1=1
NSSAI_SD_2=5

# ============================================================================
# UE Data Network Configuration
# ============================================================================
# Slice 1 subnets (SMF/UPF - existing)
SMF_SUBNET4=10.45.0.0/16
SMF_SUBNET6=2001:db8:cafe::/48
UPF_IP=172.20.0.7

# Slice 2 subnets (SMF2/UPF2 - added for anomaly detection second slice)
SMF2_SUBNET4=10.46.0.0/16
SMF2_SUBNET6=2001:db8:babe::/48
UPF2_IP=172.20.0.23

# ============================================================================
# Logging Configuration
# ============================================================================
# LOG_LEVEL: Verbosity of logs (debug, info, warning, error)
LOG_LEVEL=info

# ============================================================================
# Docker Network Configuration
# ============================================================================
# Network name and subnet for inter-NF communication
DOCKER_NETWORK=5g-core-network
DOCKER_SUBNET=172.20.0.0/24

# ============================================================================
# MongoDB Configuration
# ============================================================================
# MongoDB is used for storing:
# - Subscriber data (UDR, UDM, HSS, PCRF, PCF)
# - Authentication information
# - Policy configurations
MONGODB_IP=172.20.0.254
MONGODB_PORT=27017
MONGODB_URI=mongodb://mongodb:27017/open5gs

# ============================================================================
# 5G Core Network Functions - Container Definitions
# ============================================================================
# Format: {NF}_CONTAINER, {NF}_IP, {NF}_*_PORT

# 1. NRF (Network Repository Function) - Service Discovery
NRF_CONTAINER=5g-core-nrf
NRF_IP=172.20.0.10
NRF_SBI_PORT=7777

# 2. SCP (Service Communication Proxy) - Routing
SCP_CONTAINER=5g-core-scp
SCP_IP=172.20.0.200
SCP_SBI_PORT=7777

# 3. SEPP (Security Edge Protection Proxy) - Inter-PLMN Security
SEPP_CONTAINER=5g-core-sepp
SEPP_IP=172.20.0.250
SEPP_SBI_PORT=7777
SEPP_N32F_PORT=7777
SEPP_SEPP_PORT=7777

# 4. AMF (Access and Mobility Management Function)
AMF_CONTAINER=5g-core-amf
AMF_IP=172.20.0.5
AMF_SBI_PORT=7777
AMF_NGAP_PORT=38412
AMF_METRICS_PORT=9090

# 5. SMF (Session Management Function) - Slice 1 (SST=1, SD=1)
SMF_CONTAINER=5g-core-smf
SMF_IP=172.20.0.4
SMF_SBI_PORT=7777
SMF_GTP_C_PORT=2123
SMF_GTP_U_PORT=2152
SMF_PFCP_PORT=8805
SMF_METRICS_PORT=9090

# 5b. SMF2 (Session Management Function) - Slice 2 (SST=1, SD=5)
SMF2_CONTAINER=5g-core-smf2
SMF2_IP=172.20.0.22
SMF2_SBI_PORT=7777
SMF2_GTP_C_PORT=2123
SMF2_GTP_U_PORT=2152
SMF2_PFCP_PORT=8805
SMF2_METRICS_PORT=9090

# 6. UPF (User Plane Function) - Data Forwarding - Slice 1 (SST=1, SD=1)
UPF_CONTAINER=5g-core-upf
UPF_GTP_U_PORT=2152
UPF_PFCP_PORT=8805
UPF_METRICS_PORT=9090

# 6b. UPF2 (User Plane Function) - Slice 2 (SST=1, SD=5)
UPF2_CONTAINER=5g-core-upf2
UPF2_GTP_U_PORT=2152
UPF2_PFCP_PORT=8805
UPF2_METRICS_PORT=9090

# 7. AUSF (Authentication Server Function)
AUSF_CONTAINER=5g-core-ausf
AUSF_IP=172.20.0.11
AUSF_SBI_PORT=7777

# 8. UDM (Unified Data Management)
UDM_CONTAINER=5g-core-udm
UDM_IP=172.20.0.12
UDM_SBI_PORT=7777

# 9. PCF (Policy Control Function)
PCF_CONTAINER=5g-core-pcf
PCF_IP=172.20.0.13
PCF_SBI_PORT=7777
PCF_METRICS_PORT=9090

# 10. NSSF (Network Slice Selection Function)
NSSF_CONTAINER=5g-core-nssf
NSSF_IP=172.20.0.14
NSSF_SBI_PORT=7777

# 11. BSF (Binding Support Function)
BSF_CONTAINER=5g-core-bsf
BSF_IP=172.20.0.15
BSF_SBI_PORT=7777

# 12. UDR (Unified Data Repository)
UDR_CONTAINER=5g-core-udr
UDR_IP=172.20.0.20
UDR_SBI_PORT=7777

# 13. WebUI (Open5GS Management Interface)
WEBUI_CONTAINER=5g-core-webui
WEBUI_IP=172.20.0.16
WEBUI_PORT=9999

# ============================================================================
# 4G/EPC Network Functions
# ============================================================================

# 14. MME (Mobility Management Entity)
MME_CONTAINER=5g-core-mme
MME_IP=172.20.0.2
MME_GTP_PORT=2123
MME_S1AP_PORT=36412
MME_METRICS_PORT=9090

# 15. SGW-C (Serving Gateway - Control Plane)
SGWC_CONTAINER=5g-core-sgwc
SGWC_IP=172.20.0.3
SGWC_GTP_PORT=2123
SGWC_PFCP_PORT=8805

# 16. SGW-U (Serving Gateway - User Plane)
SGWU_CONTAINER=5g-core-sgwu
SGWU_IP=172.20.0.6
SGWU_GTP_U_PORT=2152
SGWU_PFCP_PORT=8805

# 17. HSS (Home Subscriber Server) - 4G Subscriber Data
HSS_CONTAINER=5g-core-hss
HSS_IP=172.20.0.8

# 18. PCRF (Policy and Charging Rules Function) - 4G Policy Control
PCRF_CONTAINER=5g-core-pcrf
PCRF_IP=172.20.0.21

# ============================================================================
# RAN Network Configuration (CU/DU Split)
# ============================================================================
# Network for CU/DU/UE internal communication (F1, ZMQ)
RAN_NETWORK=ran-network
RAN_SUBNET=172.21.0.0/24

# CU (Central Unit) - bridges core-network and ran-network
CU_RAN_IP=172.21.0.50
CU_CORE_IP=172.20.0.50

# DU (Distributed Unit) - bridges ran-network and ric-network
DU_RAN_IP=172.21.0.51
DU_RIC_IP=172.22.0.51

# UE (User Equipment) - ZMQ virtual radio
UE_IP=172.21.0.34

# F1 Interface (CU <-> DU)
F1_PORT=2153

# ============================================================================
# Near-RT RIC Network Configuration
# ============================================================================
# Network for RIC platform components
RIC_NETWORK=ric-network
RIC_SUBNET=172.22.0.0/24

# RIC Platform Components
RIC_DBAAS_IP=172.22.0.214
RIC_E2TERM_IP=172.22.0.210
RIC_E2MGR_IP=172.22.0.211
RIC_SUBMGR_IP=172.22.0.212
RIC_RTMGR_IP=172.22.0.213
RIC_A1MEDIATOR_IP=172.22.0.215
RIC_APPMGR_IP=172.22.0.216

# E2 Interface (DU -> RIC)
E2_SCTP_PORT=36421

# ============================================================================
# srsRAN Configuration
# ============================================================================
# Radio parameters (ZMQ virtual radio)
SRSRAN_DL_ARFCN=368500
SRSRAN_BAND=3
SRSRAN_BW_MHZ=20
SRSRAN_COMMON_SCS=15
SRSRAN_PCI=1
SRSRAN_SRATE=23.04e6

# ============================================================================
# TUN Interface Configuration (Data Plane)
# ============================================================================
# TUN interfaces must be created on the host with scripts/setup-host-tun.sh
# Network forwarding must be enabled with scripts/setup-host-network.sh
TUN_INTERFACE=ogstun
TUN_INTERFACE2=ogstun2
TUN_INTERFACE3=ogstun3

TUN_IPV4=10.45.0.1/16
TUN_IPV6=2001:db8:cafe::1/48

TUN_IPV4_2=10.46.0.1/16
TUN_IPV6_2=2001:db8:babe::1/48

TUN_IPV4_3=10.47.0.1/16
TUN_IPV6_3=2001:db8:face::1/48

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_DIR=./logs
LOG_SUMMARY_FILE=${LOG_DIR}/startup_summary.log

# ============================================================================
# NOTES FOR OPERATORS
# ============================================================================
# 1. PLMN Configuration:
#    - Change MCC/MNC to match your network identity
#    - Test networks typically use 001/01
#    - Commercial networks use actual country codes and operator codes
#
# 2. Security Keys:
#    - Initial subscriber data uses test keys
#    - Use WebUI to update K, OPc, and AMF values
#    - Never use test keys in production!
#
# 3. Network Architecture:
#    - All NFs communicate on Docker internal network (172.20.0.0/16)
#    - Data traffic passes through TUN interfaces (10.45.0.0/16, etc.)
#    - UE subnets must be configured in SMF
#
# 4. Data Plane Setup:
#    - Run scripts/setup-host-tun.sh to create TUN interfaces
#    - Run scripts/setup-host-network.sh to enable IP forwarding and NAT
#    - Verify with: sysctl net.ipv4.ip_forward
#
# 5. WebUI Access:
#    - URL: http://localhost:9999
#    - Default username: admin
#    - Default password: 1423
#    - Change password immediately in production!
#
# 6. MongoDB:
#    - Replica set: rs0 (single node in this deployment)
#    - Database: open5gs
#    - Persistent storage in: ./mongodb_data volume
