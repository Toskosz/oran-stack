# 5G Core Network Function - Docker Compose Configuration
# This file documents the IP allocation for all NFs on the Docker internal network

# ========================================================================
# Docker Network Configuration
# ========================================================================
DOCKER_NETWORK=5g-core-network
DOCKER_SUBNET=172.20.0.0/16

# ========================================================================
# MongoDB Configuration
# ========================================================================
MONGODB_IP=172.20.0.254
MONGODB_PORT=27017
MONGODB_URI=mongodb://mongodb:27017/open5gs

# ========================================================================
# 5G Core NFs - IP Allocation (172.20.0.x)
# ========================================================================

# 1st: NRF (Network Repository Function)
NRF_CONTAINER=5g-core-nrf
NRF_IP=172.20.0.10
NRF_SBI_PORT=7777

# 2nd: SCP (Service Communication Proxy)
SCP_CONTAINER=5g-core-scp
SCP_IP=172.20.0.200
SCP_SBI_PORT=7777

# 3rd: SEPP (Security Edge Protection Proxy)
SEPP_CONTAINER=5g-core-sepp
SEPP_IP=172.20.0.250
SEPP_SBI_PORT=7777
SEPP_N32F_PORT=7777
SEPP_SEPP_PORT=7777

# 4th: AMF (Access and Mobility Function)
AMF_CONTAINER=5g-core-amf
AMF_IP=172.20.0.5
AMF_SBI_PORT=7777
AMF_NGAP_PORT=38412
AMF_METRICS_PORT=9090

# 5th: SMF (Session Management Function)
SMF_CONTAINER=5g-core-smf
SMF_IP=172.20.0.4
SMF_SBI_PORT=7777
SMF_GTP_C_PORT=2123
SMF_GTP_U_PORT=2152
SMF_PFCP_PORT=8805
SMF_METRICS_PORT=9090

# 6th: UPF (User Plane Function)
UPF_CONTAINER=5g-core-upf
UPF_IP=172.20.0.7
UPF_GTP_U_PORT=2152
UPF_PFCP_PORT=8805
UPF_METRICS_PORT=9090

# 7th: AUSF (Authentication Server Function)
AUSF_CONTAINER=5g-core-ausf
AUSF_IP=172.20.0.11
AUSF_SBI_PORT=7777

# 8th: UDM (Unified Data Management)
UDM_CONTAINER=5g-core-udm
UDM_IP=172.20.0.12
UDM_SBI_PORT=7777

# 9th: PCF (Policy Control Function)
PCF_CONTAINER=5g-core-pcf
PCF_IP=172.20.0.13
PCF_SBI_PORT=7777
PCF_METRICS_PORT=9090

# 10th: NSSF (Network Slice Selection Function)
NSSF_CONTAINER=5g-core-nssf
NSSF_IP=172.20.0.14
NSSF_SBI_PORT=7777

# 11th: BSF (Binding Support Function)
BSF_CONTAINER=5g-core-bsf
BSF_IP=172.20.0.15
BSF_SBI_PORT=7777

# 12th: UDR (Unified Data Repository)
UDR_CONTAINER=5g-core-udr
UDR_IP=172.20.0.20
UDR_SBI_PORT=7777

# ========================================================================
# 4G/Legacy Network Functions
# ========================================================================

# 13th: MME (Mobility Management Entity)
MME_CONTAINER=5g-core-mme
MME_IP=172.20.0.2
MME_GTP_PORT=2123
MME_S1AP_PORT=36412
MME_METRICS_PORT=9090

# 14th: SGW-C (Serving Gateway - Control Plane)
SGWC_CONTAINER=5g-core-sgwc
SGWC_IP=172.20.0.3
SGWC_GTP_PORT=2123
SGWC_PFCP_PORT=8805

# 15th: SGW-U (Serving Gateway - User Plane)
SGWU_CONTAINER=5g-core-sgwu
SGWU_IP=172.20.0.6
SGWU_GTP_U_PORT=2152
SGWU_PFCP_PORT=8805

# 16th: HSS (Home Subscriber Server)
HSS_CONTAINER=5g-core-hss
HSS_IP=172.20.0.1

# 17th: PCRF (Policy and Charging Rules Function)
PCRF_CONTAINER=5g-core-pcrf
PCRF_IP=172.20.0.21

# ========================================================================
# Logging Configuration
# ========================================================================
LOG_DIR=./logs
LOG_SUMMARY_FILE=${LOG_DIR}/startup_summary.log
LOG_TIMESTAMP=$(date +%Y%m%d_%H%M%S)
